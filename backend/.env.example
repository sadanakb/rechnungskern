# Application Settings
APP_NAME=RechnungsKern
APP_VERSION=1.0.0
DEBUG=True

# Database
DATABASE_URL=sqlite:///./data/rechnungskern.db

# CORS Origins
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# OCR Settings
TESSERACT_LANG=deu
OCR_DPI=300

# XRechnung
XRECHNUNG_VERSION=3.0.2
ZUGFERD_PROFILE=EXTENDED

# KoSIT Validator (optional)
KOSIT_VALIDATOR_URL=http://localhost:8081/validate
KOSIT_HEALTH_CHECK_INTERVAL=300

# Upload Settings
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=[".pdf",".xml"]

# Azure OpenAI (DSGVO-konform, Daten bleiben in der EU — Sweden Central)
# Bevorzugt gegenüber OPENAI_API_KEY wenn beide gesetzt sind
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<dein-name>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_VISION=gpt-4o

# OpenAI direkt (Fallback für lokale Entwicklung, Daten gehen in die USA)
# Nur nutzen wenn kein Azure-Key konfiguriert ist
OPENAI_API_KEY=
